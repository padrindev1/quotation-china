# ============================================================
#  OKTZ ERP - Configurações de Ambiente
#  COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
#  NUNCA COMMITE O ARQUIVO .env NO GIT
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Banco de Dados
DB_PATH=./data/erp.db

# JWT - Gere chaves fortes com: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_SECRETA_ALEATORIA_DE_MINIMO_64_CARACTERES
JWT_REFRESH_SECRET=SUBSTITUA_POR_OUTRA_CHAVE_SECRETA_DIFERENTE_DA_ACIMA

# Admin padrão (altere após o primeiro acesso!)
ADMIN_DEFAULT_PASSWORD=OKTZ@2024!

# Gmail - Use App Password (NÃO use sua senha principal)
# Como configurar: https://myaccount.google.com/apppasswords
GMAIL_USER=seu.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# WhatsApp (true = ativa integração, precisará escanear QR code)
WHATSAPP_ENABLED=false

# Emails padrão para cópia em notificações
EMAIL_FINANCEIRO=financeiro@empresa.com.br
EMAIL_CONTABILIDADE=contabilidade@empresa.com.br
EMAIL_ESTOQUE=estoque@empresa.com.br
EMAIL_DIRETOR_FINANCEIRO=diretor.financeiro@empresa.com.br

# ── Rastreamento de Vessels (opcional) ───────────────────────────────────────
# Câmbio em tempo real usa AwesomeAPI (GRATUITO — sem chave necessária)
#
# Para rastreamento de navios, escolha um provider e configure a chave:
#
# GRATUITO (registro obrigatório):
#   AISStream.io   → https://aisstream.io  (WebSocket, 0$/mês)
#
# PAGO — recomendados para assinatura:
#   VesselFinder   → https://api.vesselfinder.com  (créditos a partir de €330)
#   Datalastic     → https://datalastic.com        (~€80/mês)
#   MarineTraffic  → https://www.marinetraffic.com (enterprise)
#
# Providers suportados: vesselFinder | marineTraffic | datalastic
VESSEL_API_KEY=
VESSEL_API_PROVIDER=vesselFinder

# ── Tarifas de Frete (cotações FCL automáticas) ───────────────────────────────
# Sem chave: tarifas são gerenciadas manualmente pelo painel (recomendado)
# Com chave: tarifas são buscadas automaticamente via API externa
#
# Providers suportados:
#   searates  → https://www.searates.com/reference/api/  (planos a partir de $49/mês)
#   freightos → https://developer.freightos.com/         (enterprise)
FREIGHT_API_KEY=
FREIGHT_API_PROVIDER=searates
